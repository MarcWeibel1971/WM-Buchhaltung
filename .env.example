# ─── WM-Buchhaltung – Environment variables ────────────────────────────────
# Copy this file to `.env` and fill in the values for your environment.
# Never commit your real `.env` file – it is listed in .gitignore.

# ─── Core ──────────────────────────────────────────────────────────────────
# Node environment. Use "production" for deployed instances.
NODE_ENV=development

# HTTP port the server listens on. Defaults to 3000.
PORT=3000

# ─── Database (MySQL) ──────────────────────────────────────────────────────
# Full MySQL connection string used by Drizzle ORM.
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://root:root@localhost:3306/wm_buchhaltung

# ─── Session / JWT ─────────────────────────────────────────────────────────
# Long, random secret used to sign session cookies. MUST be set in
# production. Generate with: openssl rand -hex 64
JWT_SECRET=

# ─── OAuth (Manus SDK) ─────────────────────────────────────────────────────
# Application ID registered with the OAuth provider.
VITE_APP_ID=

# Base URL of the OAuth server (without trailing slash).
OAUTH_SERVER_URL=

# openId of the instance owner (full-admin fallback). Optional.
OWNER_OPEN_ID=

# ─── Built-in LLM (Forge) ──────────────────────────────────────────────────
# Endpoint and API key for the built-in LLM used by document/invoice analysis.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─── S3 / Object storage ───────────────────────────────────────────────────
# AWS S3 credentials for storing uploaded documents. Use an S3-compatible
# endpoint (MinIO, Cloudflare R2, etc.) by setting AWS_ENDPOINT_URL.
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# Optional: custom endpoint for S3-compatible providers.
# AWS_ENDPOINT_URL=https://s3.example.com
